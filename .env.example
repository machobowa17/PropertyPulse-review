# PropertyPulse — environment variables
# Copy to .env and fill in real values for deployment

# Main application database
POSTGRES_DB=ukproperty
POSTGRES_USER=ukproperty
POSTGRES_PASSWORD=changeme

# Redis
REDIS_URL=redis://redis:6379/0

# Frontend CORS origins
ALLOWED_ORIGINS=http://localhost:3001,http://frontend:80

# Admin API key (required for /data-freshness endpoint)
ADMIN_API_KEY=

# Sentry APM (leave blank to disable; set to DSN from sentry.io to enable)
SENTRY_DSN=
VITE_SENTRY_DSN=

# Airflow database (separate from app DB)
AIRFLOW_POSTGRES_DB=airflow
AIRFLOW_POSTGRES_USER=airflow
AIRFLOW_POSTGRES_PASSWORD=changeme

# Airflow admin (created on first init)
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=changeme

# Airflow config
AIRFLOW__WEBSERVER__EXPOSE_CONFIG=false
